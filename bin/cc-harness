#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
# cc-harness — multi-session Claude Code launcher
# https://github.com/alejandro-soto-franco/cc-harness
#
# Usage: cc-harness            # attach (creating the session if needed)
#        cc-harness new        # spawn a new claude session and attach to it
#        cc-harness kill       # pick a session window to kill
#        cc-harness --help

set -euo pipefail

CCH_SESSION="${CCH_SESSION:-cc-harness}"
CCH_FLAGS="${CCH_FLAGS:---dangerously-skip-permissions}"
CCH_CLAUDE="${CCH_CLAUDE:-claude}"
CCH_SELF="$(readlink -f "$0")"
TMUX_FLAGS="${TMUX_FLAGS:-}"
CCH_VERBOSE="${CCH_VERBOSE:-0}"
CCH_QUIET="${CCH_QUIET:-0}"

readonly EXIT_OK=0
readonly EXIT_GENERIC=1
readonly EXIT_USAGE=2
readonly EXIT_CONFIG=3
readonly EXIT_TMUX=4
readonly EXIT_DEPS=5

_die() {
    # _die <exit-code> <subcmd> <message...>
    local code="$1" subcmd="$2"; shift 2
    printf "cc-harness: %s: %s\n" "$subcmd" "$*" >&2
    exit "$code"
}

_warn() {
    local subcmd="$1"; shift
    printf "cc-harness: %s: %s\n" "$subcmd" "$*" >&2
}

# Wrapper so tests (and advanced users) can target an isolated tmux server
# via TMUX_FLAGS (e.g. "-L cch-test-1234"). Empty in normal use.
_tmux() { tmux $TMUX_FLAGS "$@"; }

# Resolve config + state paths in priority order: CCH_HOME → XDG → legacy.
# Populates: CCH_CONF, CCH_STATE_DIR, CCH_LOCK, CCH_LOG, CCH_MIGRATED_MARKER.
_lib_paths() {
    local xdg_config="${XDG_CONFIG_HOME:-$HOME/.config}"
    local xdg_state="${XDG_STATE_HOME:-$HOME/.local/state}"
    local legacy_dir="$HOME/cc-harness"

    if [[ -n "${CCH_HOME:-}" ]]; then
        CCH_CONF="$CCH_HOME/projects.conf"
        CCH_STATE_DIR="$CCH_HOME"
    elif [[ -f "$xdg_config/cc-harness/projects.conf" ]]; then
        CCH_CONF="$xdg_config/cc-harness/projects.conf"
        CCH_STATE_DIR="$xdg_state/cc-harness"
    elif [[ -f "$legacy_dir/projects.conf" ]]; then
        CCH_CONF="$legacy_dir/projects.conf"
        CCH_STATE_DIR="$legacy_dir"
    else
        CCH_CONF="$xdg_config/cc-harness/projects.conf"
        CCH_STATE_DIR="$xdg_state/cc-harness"
    fi
    CCH_LOCK="${XDG_RUNTIME_DIR:-/tmp}/cc-harness-$UID.lock"
    CCH_LOG="$CCH_STATE_DIR/cc-harness.log"
    CCH_MIGRATED_MARKER="$CCH_STATE_DIR/.migrated-from-legacy"
}

# One-time XDG migration. Copies $HOME/cc-harness/projects.conf to
# $XDG_CONFIG_HOME/cc-harness/, writes a marker so we never run again,
# and re-points CCH_CONF. Skipped when CCH_HOME is set, when the legacy
# file is absent, or when the marker already exists.
_lib_migrate() {
    local legacy_dir="$HOME/cc-harness"
    local xdg_config="${XDG_CONFIG_HOME:-$HOME/.config}/cc-harness"
    local xdg_state="${XDG_STATE_HOME:-$HOME/.local/state}/cc-harness"
    local marker="$xdg_state/.migrated-from-legacy"

    [[ -n "${CCH_HOME:-}" ]] && return 0
    [[ -f "$legacy_dir/projects.conf" ]] || return 0
    [[ -f "$marker" ]] && return 0
    [[ -f "$xdg_config/projects.conf" ]] && return 0

    mkdir -p "$xdg_config" "$xdg_state"
    cp -p "$legacy_dir/projects.conf" "$xdg_config/projects.conf"
    : > "$marker"

    {
        echo "cc-harness: migrated config from ~/cc-harness/ to $xdg_config/"
        echo "cc-harness: legacy ~/cc-harness/ left in place; remove when ready"
    } >&2

    CCH_CONF="$xdg_config/projects.conf"
    CCH_STATE_DIR="$xdg_state"
    CCH_LOG="$CCH_STATE_DIR/cc-harness.log"
    CCH_MIGRATED_MARKER="$marker"
}

_have() { command -v "$1" >/dev/null 2>&1; }

# Parse one config line into key=value records on stdout.
# Schema: "label = path [| flags] [#tag1 #tag2 ...]"
# Returns 1 on blank/comment lines.
_lib_parse() {
    local line="$1" label rest path flags tags
    line="${line#"${line%%[![:space:]]*}"}"
    [[ -z "$line" || "$line" == \#* ]] && return 1

    label="${line%%=*}"
    label="${label%"${label##*[![:space:]]}"}"
    rest="${line#*=}"
    rest="${rest#"${rest%%[![:space:]]*}"}"

    tags=""
    while [[ "$rest" =~ [[:space:]]\#([a-zA-Z0-9_-]+)[[:space:]]*$ ]]; do
        tags="${BASH_REMATCH[1]} $tags"
        rest="${rest% \#${BASH_REMATCH[1]}*}"
        rest="${rest%"${rest##*[![:space:]]}"}"
    done
    tags="${tags% }"

    if [[ "$rest" == *"|"* ]]; then
        flags="${rest#*|}"
        flags="${flags#"${flags%%[![:space:]]*}"}"
        flags="${flags%"${flags##*[![:space:]]}"}"
        path="${rest%%|*}"
        path="${path%"${path##*[![:space:]]}"}"
    else
        path="${rest%"${rest##*[![:space:]]}"}"
        flags=""
    fi

    printf "label=%s\npath=%s\nflags=%s\ntags=%s\n" "$label" "$path" "$flags" "$tags"
}

# Run _lib_parse on a config line and assign label/path/flags/tags as
# the caller's local variables — without eval, so flag values can't be
# interpreted as shell commands.
_lib_assign() {
    local line="$1" key value
    label= path= flags= tags=
    while IFS='=' read -r key value; do
        case "$key" in
            label) label="$value" ;;
            path)  path="$value" ;;
            flags) flags="$value" ;;
            tags)  tags="$value" ;;
        esac
    done < <(_lib_parse "$line" 2>/dev/null)
    [[ -n "$label" ]]
}

_lib_validate_label() {
    local label="$1"
    [[ -z "$label" ]] && { echo "cc-harness: label cannot be empty" >&2; return 3; }
    (( ${#label} > 32 )) && { echo "cc-harness: label too long (max 32)" >&2; return 3; }
    [[ "$label" =~ ^[a-zA-Z0-9_-]+$ ]] || {
        echo "cc-harness: label must match [a-zA-Z0-9_-]+" >&2; return 3; }
    return 0
}

_lib_validate_tag() {
    local tag="$1"
    [[ -z "$tag" ]] && { echo "cc-harness: tag cannot be empty" >&2; return 3; }
    (( ${#tag} > 24 )) && { echo "cc-harness: tag too long (max 24)" >&2; return 3; }
    [[ "$tag" =~ ^[a-zA-Z0-9_-]+$ ]] || {
        echo "cc-harness: tag must match [a-zA-Z0-9_-]+" >&2; return 3; }
    return 0
}

_lib_resolve_path() {
    local p="$1"; p="${p/#\~/$HOME}"; printf "%s" "$p"
}

_lib_validate_path() {
    local p; p="$(_lib_resolve_path "$1")"
    [[ -d "$p" ]] || { echo "cc-harness: not a directory: $p" >&2; return 3; }
    return 0
}

# Append a timestamped record to $CCH_LOG when CCH_VERBOSE=1.
# Rotates at 1MiB, keeps three files.
_lib_log() {
    [[ "${CCH_VERBOSE:-0}" -eq 1 ]] || return 0
    mkdir -p "$CCH_STATE_DIR"
    if [[ -f "$CCH_LOG" ]] && (( $(stat -c%s "$CCH_LOG" 2>/dev/null || stat -f%z "$CCH_LOG" 2>/dev/null || echo 0) > 1048576 )); then
        for i in 2 1; do
            [[ -f "$CCH_LOG.$i" ]] && mv "$CCH_LOG.$i" "$CCH_LOG.$((i+1))"
        done
        mv "$CCH_LOG" "$CCH_LOG.1"
    fi
    printf "[%s] %s\n" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$*" >> "$CCH_LOG"
}

# flock-based mutex around config-mutating ops.
_lib_with_lock() {
    # _lib_with_lock <subcmd> <function-to-run> [args...]
    local subcmd="$1" fn="$2"; shift 2
    mkdir -p "$(dirname "$CCH_LOCK")"
    exec 9>"$CCH_LOCK" || _die "$EXIT_GENERIC" "$subcmd" "could not open lockfile $CCH_LOCK"
    if ! flock -n 9; then
        _die "$EXIT_GENERIC" "$subcmd" "another cc-harness is mutating config (lock held)"
    fi
    "$fn" "$@"
    local rc=$?
    exec 9>&-
    return "$rc"
}

_lib_preflight_claude() {
    if ! command -v "$CCH_CLAUDE" >/dev/null 2>&1; then
        _die "$EXIT_DEPS" preflight \
            "claude binary not found on PATH (or via \$CCH_CLAUDE=$CCH_CLAUDE)"
    fi
}

_lib_preflight_tmux() {
    command -v tmux >/dev/null 2>&1 \
        || _die "$EXIT_DEPS" preflight "tmux not installed"
    local v
    v="$(tmux -V | awk '{print $2}' | tr -d '[:alpha:]')"
    awk -v v="$v" 'BEGIN{ exit !(v+0 >= 3.0) }' \
        || _die "$EXIT_DEPS" preflight "requires tmux >= 3.0 (found $v)"
}

# Strip leading global flags (-v/-q/--no-color) so subcommand parsing
# only sees what's meant for it. Sets CCH_REMAINING_ARGS.
_lib_parse_global_flags() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) CCH_VERBOSE=1; shift ;;
            -q|--quiet)   CCH_QUIET=1;   shift ;;
            --no-color)   NO_COLOR=1;    shift ;;
            *) break ;;
        esac
    done
    CCH_REMAINING_ARGS=("$@")
}

_seed_conf() {
    mkdir -p "$(dirname "$CCH_CONF")"
    cat > "$CCH_CONF" <<'EOF'
# cc-harness projects — one per line, "label = path"
# Lines starting with # are comments. ~ expands to $HOME.
# Order shown in menu = order here. Edit freely; takes effect immediately.

polybius     = ~/Polybius
polybius-ca  = ~/asf-capital
pmp          = ~/pmp
stratum      = ~/stratum
fleming      = ~/fleming
nse          = ~/3d-navier-stokes
landscape    = ~/governing-landscape
tactic       = ~/tactic-ranker
job-hub      = ~/job-hub
lemma        = ~/lemma
malliavin    = ~/malliavin
home         = ~
EOF
}

_pick() {
    # $1 = prompt label; stdin = newline-separated items; stdout = chosen item
    local prompt="$1"
    if _have fzf; then
        fzf --prompt="$prompt " --height=40% --reverse --border --no-info --no-mouse
    else
        local items=() line
        while IFS= read -r line; do items+=("$line"); done
        local i=0
        for line in "${items[@]}"; do printf "  %2d) %s\n" "$((++i))" "$line" >&2; done
        printf "%s " "$prompt" >&2
        local n; read -r n </dev/tty
        if [[ "$n" =~ ^[0-9]+$ ]] && (( n >= 1 && n <= ${#items[@]} )); then
            printf "%s\n" "${items[$((n-1))]}"
        fi
    fi
}

_projects() {
    grep -vE '^\s*(#|$)' "$CCH_CONF" \
        | sed -E 's/[[:space:]]*=[[:space:]]*/=/'
}

_spawn() {
    local label="$1" path="$2" extra_flags="${3:-}"
    _lib_validate_label "$label" || exit "$EXIT_CONFIG"
    path="$(_lib_resolve_path "$path")"
    [[ -d "$path" ]] || _die "$EXIT_CONFIG" spawn "no such dir: $path"
    _lib_preflight_claude
    _lib_preflight_tmux
    if _tmux list-windows -t "$CCH_SESSION" -F '#W' 2>/dev/null | grep -qx -- "$label"; then
        _tmux select-window -t "$CCH_SESSION:$label"
    else
        _tmux new-window -t "$CCH_SESSION:" -n "$label" -c "$path" \
            "$CCH_CLAUDE $CCH_FLAGS $extra_flags"
        # Keep the pane around when claude exits so the user sees what happened
        # and the menu can mark it [dead] on next attach. Best-effort: if claude
        # exited fast enough that the window already vanished, ignore.
        _tmux set-window-option -t "$CCH_SESSION:$label" remain-on-exit on \
            2>/dev/null || true
        _tmux select-window -t "$CCH_SESSION:$label" 2>/dev/null || true
    fi
    _lib_log "spawn label=$label path=$path"
}

_cmd_new() {
    local mode=ask label=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --fresh)  mode=fresh; shift ;;
            --switch) mode=switch; shift ;;
            -*)       _die "$EXIT_USAGE" new "unknown flag: $1" ;;
            *)        label="$1"; shift ;;
        esac
    done

    if [[ -z "$label" ]]; then
        local pick
        pick="$(_projects | _pick 'project>')" || return 0
        [[ -z "${pick:-}" ]] && return 0
        label="$(printf "%s" "${pick%%=*}" | tr -d '[:space:]')"
    fi

    local line path flags tags
    line="$(_lookup_project "$label")" \
        || _die "$EXIT_CONFIG" new "no such project: $label"
    _lib_assign "$line" || _die "$EXIT_CONFIG" new "could not parse: $line"

    local exists=0
    _tmux list-windows -t "$CCH_SESSION" -F '#W' 2>/dev/null \
        | grep -qx -- "$label" && exists=1

    case "$mode" in
        switch)
            (( exists )) || _die "$EXIT_TMUX" new "no window for $label"
            _tmux select-window -t "$CCH_SESSION:$label"
            ;;
        fresh)
            local n=2
            while _tmux list-windows -t "$CCH_SESSION" -F '#W' 2>/dev/null \
                | grep -qx -- "$label-$n"; do n=$((n+1)); done
            _spawn "$label-$n" "$path" "$flags"
            ;;
        ask)
            if (( exists )); then
                if [[ -t 0 ]]; then
                    read -r -p "[s]witch / [f]resh / [c]ancel? " ans
                else
                    ans=s
                fi
                case "${ans:-s}" in
                    s|S|"") _tmux select-window -t "$CCH_SESSION:$label" ;;
                    f|F)
                        local n=2
                        while _tmux list-windows -t "$CCH_SESSION" -F '#W' 2>/dev/null \
                            | grep -qx -- "$label-$n"; do n=$((n+1)); done
                        _spawn "$label-$n" "$path" "$flags"
                        ;;
                    *) return 0 ;;
                esac
            else
                _spawn "$label" "$path" "$flags"
            fi
            ;;
    esac
}

_lookup_project() {
    local want="$1" line label path flags tags
    while IFS= read -r line; do
        _lib_assign "$line" || continue
        [[ "$label" == "$want" ]] && { printf "%s\n" "$line"; return 0; }
    done < <(grep -vE '^\s*(#|$)' "$CCH_CONF")
    return 1
}

_cmd_kill() {
    local all=0 tag="" dry=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)      all=1; shift ;;
            --tag)      tag="${2:-}"; shift 2 ;;
            --dry-run)  dry=1; shift ;;
            -*) _die "$EXIT_USAGE" kill "unknown flag: $1" ;;
            *)  _die "$EXIT_USAGE" kill "unexpected arg: $1" ;;
        esac
    done

    local windows pick
    windows="$(_tmux list-windows -t "$CCH_SESSION" -F '#W' 2>/dev/null | grep -vx menu || true)"
    if [[ -z "$windows" ]]; then
        printf "(no sessions to kill)\n" >&2
        return 0
    fi
    if [[ -n "$tag" ]]; then
        windows="$(_filter_windows_by_tag "$windows" "$tag")"
        [[ -z "$windows" ]] && {
            printf "(no sessions match tag #%s)\n" "$tag" >&2
            return 0
        }
    fi
    if (( all )); then
        while IFS= read -r w; do
            (( dry )) && { printf "would kill: %s\n" "$w"; continue; }
            _tmux kill-window -t "$CCH_SESSION:$w"
        done <<< "$windows"
        return 0
    fi
    pick="$(printf "%s\n" "$windows" | _pick 'kill>')" || return 0
    [[ -z "${pick:-}" ]] && return 0
    if (( dry )); then printf "would kill: %s\n" "$pick"; return 0; fi
    if [[ -t 0 ]]; then
        printf "kill window '%s'? [y/N] " "$pick" >&2
        local ans; read -r ans </dev/tty
        [[ "$ans" == "y" || "$ans" == "Y" ]] || return 0
    fi
    _tmux kill-window -t "$CCH_SESSION:$pick"
}

_filter_windows_by_tag() {
    local windows="$1" want_tag="$2" out="" line label path flags tags w t base
    while IFS= read -r line; do
        _lib_assign "$line" || continue
        for w in $windows; do
            base="${w%-[0-9]*}"
            [[ "$base" == "$label" ]] || continue
            for t in $tags; do
                [[ "${t,,}" == "${want_tag,,}" ]] && out+="$w"$'\n'
            done
        done
    done < <(grep -vE '^\s*(#|$)' "$CCH_CONF")
    printf "%s" "${out%$'\n'}"
}

_cmd_menu() {
    while true; do
        clear
        cat <<EOF
┌─ cc-harness ─────────────────────────────────────────┐
│  multi-session Claude Code launcher                  │
│  flags: $CCH_FLAGS
└──────────────────────────────────────────────────────┘

Active sessions:
EOF
        local windows
        windows="$(_tmux list-windows -t "$CCH_SESSION" \
            -F '  [#I] #W  →  #{pane_current_path}' 2>/dev/null \
            | grep -vE '\] menu  ' || true)"
        if [[ -z "$windows" ]]; then
            echo "  (none — pick 'new' to start one)"
        else
            echo "$windows"
        fi
        cat <<'EOF'

Tmux keys (Ctrl-b is the prefix):
  prefix + 0       jump back to this menu
  prefix + 1..9    jump to session window N
  prefix + n / p   next / prev window
  prefix + w       interactive window list
  prefix + d       detach (sessions keep running)

EOF
        local action
        action="$(printf "new\nkill\nedit projects.conf\ndetach\nquit (kill harness)\n" \
            | _pick 'cc-harness>')" || action="detach"
        case "$action" in
            new)                 _cmd_new ;;
            kill)                _cmd_kill ;;
            "edit projects.conf") "${EDITOR:-vi}" "$CCH_CONF" ;;
            detach)              _tmux detach-client; return ;;
            "quit (kill harness)")
                printf "kill the entire harness session and all running claudes? [y/N] " >&2
                local ans; read -r ans </dev/tty
                if [[ "$ans" == "y" || "$ans" == "Y" ]]; then
                    _tmux kill-session -t "$CCH_SESSION"
                    exit 0
                fi
                ;;
            *) ;;
        esac
    done
}

_cmd_attach() {
    [[ -f "$CCH_CONF" ]] || _seed_conf
    if ! _tmux has-session -t "$CCH_SESSION" 2>/dev/null; then
        _tmux new-session -d -s "$CCH_SESSION" -n menu \
            "exec '$CCH_SELF' menu"
        _tmux set-option -t "$CCH_SESSION" status-style "bg=colour236,fg=colour250"
        _tmux set-option -t "$CCH_SESSION" status-left  "#[bold] cc-harness #[default]│ "
        _tmux set-option -t "$CCH_SESSION" status-right "#(date +%H:%M) "
        _tmux set-option -t "$CCH_SESSION" mouse on
        # Keep windows around when claude exits so users can read tracebacks
        # and the next attach can rename them [dead].
        _tmux set-window-option -t "$CCH_SESSION" remain-on-exit on 2>/dev/null || true
    else
        # Self-heal: if the menu window has been killed, recreate it at index 0.
        if ! _tmux list-windows -t "$CCH_SESSION" -F '#W' 2>/dev/null | grep -qx menu; then
            _tmux new-window -t "$CCH_SESSION:0" -n menu \
                "exec '$CCH_SELF' menu" 2>/dev/null \
                || _tmux new-window -t "$CCH_SESSION:" -n menu \
                       "exec '$CCH_SELF' menu"
        fi
        # Stale-window detection: rename windows whose pane PID is dead.
        while IFS=$'\t' read -r idx wname pid; do
            [[ "$wname" == menu || "$wname" == \[dead\]* ]] && continue
            if ! kill -0 "$pid" 2>/dev/null; then
                _tmux rename-window -t "$CCH_SESSION:$idx" "[dead] $wname"
            fi
        done < <(_tmux list-windows -t "$CCH_SESSION" -F '#I	#W	#{pane_pid}' 2>/dev/null)
    fi
    if [[ -n "${TMUX:-}" ]]; then
        _tmux switch-client -t "$CCH_SESSION"
    else
        _tmux attach-session -t "$CCH_SESSION"
    fi
}

_help() {
    cat <<EOF
cc-harness — Claude Code multi-session launcher

Usage: cc-harness [command]
  (no args)    launch / attach the harness tmux session
  new          spawn a new claude session (project picker)
  kill         kill an existing claude session
  menu         (internal) run the menu loop in window 0
  -h, --help   show this help

Config:
  $CCH_CONF        edit to add or remove projects
Env:
  CCH_FLAGS        flags passed to claude on every spawn
                   (default: --dangerously-skip-permissions)
  CCH_HOME         override harness dir (default: ~/cc-harness)
  CCH_SESSION      tmux session name (default: cc-harness)
  CCH_CLAUDE       path to the claude binary (default: claude on PATH)

Inside the harness (Ctrl-b is the tmux prefix):
  prefix + 0       menu window
  prefix + 1..9    session N
  prefix + w       interactive window list
  prefix + d       detach
  prefix + ,       rename current window
  prefix + &       kill current window (close that claude session)
EOF
}

_lib_parse_global_flags "$@"
set -- "${CCH_REMAINING_ARGS[@]}"

_lib_paths
# Skip migration for hidden/debug commands (underscore-prefixed) so they
# don't mutate state during introspection.
case "${1:-}" in _*) ;; *) _lib_migrate ;; esac

cmd="${1:-attach}"
[[ $# -gt 0 ]] && shift
case "$cmd" in
    attach|"")    _cmd_attach "$@" ;;
    menu)         _cmd_menu "$@" ;;
    new)          _cmd_new "$@" ;;
    kill)         _cmd_kill "$@" ;;
    list)
        grep -vE '^\s*(#|$)' "$CCH_CONF" 2>/dev/null || true
        ;;
    _debug-paths) printf "config=%s\nstate=%s\nlock=%s\n" \
                      "$CCH_CONF" "$CCH_STATE_DIR" "$CCH_LOCK" ;;
    _parse-line)       _lib_parse "${1:-}" ;;
    _validate-label)   _lib_validate_label "${1:-}" ;;
    _validate-tag)     _lib_validate_tag "${1:-}" ;;
    _validate-path)    _lib_validate_path "${1:-}" ;;
    _preflight-claude) _lib_preflight_claude ;;
    _preflight-tmux)   _lib_preflight_tmux ;;
    -h|--help)    _help ;;
    *)
        printf "cc-harness: unknown command: %s\n" "$cmd" >&2
        _help >&2
        exit 2
        ;;
esac
